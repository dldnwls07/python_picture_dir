   <string notr="true">
    QMainWindow {
      background-color: #1e1e2e;
    }
    QWidget {
      color: #f5f5f5;
      font-family: "Pretendard", "Noto Sans KR", "Malgun Gothic", "-apple-system", sans-serif;
