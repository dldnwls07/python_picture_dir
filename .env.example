# =============================================================
# 감정 일기장 환경변수 설정 파일
# 이 파일을 복사하여 .env로 저장 후 실제 값을 입력하세요.
#   cp .env.example .env
# .env 파일은 절대 Git에 커밋하지 마세요 (.gitignore에 포함됨)
# =============================================================

# [필수] Google Gemini AI API 키
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# [선택] 기상청(KMA) 초단기예보 API 설정 — 미입력 시 Open-Meteo fallback 사용
# 발급: https://www.data.go.kr/tcs/dss/selectApiDataDetailView.do?publicDataPk=15084084
# 주의: URL 디코딩된 원문 키를 입력하세요. (내부에서 unquote() 자동 처리)
KMA_SERVICE_KEY=your_kma_service_key_here
KMA_WEATHER_URL=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0/getUltraSrtFcst

# [선택] 날씨 제공자 선택
#   auto       — KMA 키가 있으면 KMA, 없으면 Open-Meteo
#   open-meteo — 항상 Open-Meteo 사용 (무료, 키 불필요)
#   kma        — 항상 KMA 사용 (KMA_SERVICE_KEY 필수)
WEATHER_PROVIDER=auto

# [선택] 수동 위치 고정 (IP 기반 위치 탐지를 건너뜀)
WEATHER_LATITUDE=
WEATHER_LONGITUDE=
WEATHER_LOCATION_NAME=

# [선택] GUI 백엔드 선택 (기본값: tk)
#   tk — Tkinter (의존성 없음, 기본)
#   qt — PyQt5 (별도 설치 필요)
EMOTION_DIARY_GUI=tk